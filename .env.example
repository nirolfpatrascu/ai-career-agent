# Anthropic API Key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Override Claude model (defaults to claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional: Rate limit (requests per hour per IP, default 10)
# RATE_LIMIT_PER_HOUR=10

# Supabase — get these from https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service role key — only for server-side (quota enforcement, terms acceptance, cron resets)
# NEVER expose this to the browser
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Adzuna Job Search API — developer.adzuna.com
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key

# Stripe — get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs — create in Stripe Dashboard → Products
STRIPE_PRICE_WEEKLY=price_weekly_id
STRIPE_PRICE_MONTHLY=price_monthly_id

# DeepL Translation API — get a free key at https://www.deepl.com/pro#developer
DEEPL_API_KEY=your-deepl-api-key
DEEPL_API_URL=https://api-free.deepl.com

# Canva Connect API — canva.com/developers → Create integration
# Used for LinkedIn banner generation (autofill brand templates + export PNG)
CANVA_CLIENT_ID=your-canva-client-id
CANVA_CLIENT_SECRET=your-canva-client-secret
# Server-side: comma-separated IDs used for validation in /api/generate-banner
CANVA_TEMPLATE_IDS=templateId1,templateId2,templateId3,templateId4,templateId5
# Client-side: individual IDs sent to the component (safe — template IDs are not secrets)
NEXT_PUBLIC_CANVA_TEMPLATE_1=templateId1
NEXT_PUBLIC_CANVA_TEMPLATE_2=templateId2
NEXT_PUBLIC_CANVA_TEMPLATE_3=templateId3
NEXT_PUBLIC_CANVA_TEMPLATE_4=templateId4
NEXT_PUBLIC_CANVA_TEMPLATE_5=templateId5
